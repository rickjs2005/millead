# ===== Infra (nuvem: Supabase + Upstash -- setup padrão, sem Docker) =====
# Supabase: use a connection string do SESSION POOLER (Dashboard > Connect),
# que funciona com Prisma e com redes IPv4. Caracteres especiais na senha
# precisam de URL-encoding (ex.: $ -> %24, # -> %23).
DATABASE_URL="postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?schema=public"
# Upstash exige TLS -- por isso rediss:// (dois "s"), não redis://.
REDIS_URL="rediss://default:SUA_SENHA@SEU-HOST.upstash.io:6379"

# Alternativa local com Docker (docker compose up -d):
# DATABASE_URL="postgresql://millead:millead@localhost:5432/millead?schema=public"
# REDIS_URL="redis://localhost:6379"

# ===== Auth =====
# Refresh token é opaco (não é JWT) -- só o access token usa segredo.
# Gere um de verdade fora de dev local, ex.: openssl rand -base64 48
JWT_ACCESS_SECRET="troque-este-segredo-por-um-de-verdade-com-32-chars-ou-mais"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ===== API =====
NODE_ENV="development"
API_PORT="4000"
CORS_ORIGIN="http://localhost:3000"

# ===== IA (Fase 7 -- opcional) =====
# Sem a chave o app funciona normalmente, mas score/mensagens/relatorios de IA
# ficam desabilitados (503 amigavel + botoes desativados na UI).
# Crie em https://console.anthropic.com (paga por uso).
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_MODEL="claude-opus-4-8"

# ===== Web =====
NEXT_PUBLIC_API_URL="http://localhost:4000"
