{
  "name": "@millead/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/main/server.ts",
    "dev:worker": "tsx watch --env-file-if-exists=../../.env src/interfaces/jobs/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx --env-file-if-exists=../../.env src/main/server.ts",
    "start:worker": "tsx --env-file-if-exists=../../.env src/interfaces/jobs/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@millead/database": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@millead/eslint-config": "workspace:*",
    "@millead/typescript-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.2"
  }
}
